{
  "expo": {
    "name": "Moonlit Tales",
    "slug": "moonlit-tales",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moonlittales",
    "userInterfaceStyle": "dark",
    "owner": "ak45h6017",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.redevolve.moonlittales"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0F16",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "in.redevolve.moonlittales"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0D0F16"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "45205019-a1e4-44c5-b0f7-cec3f1da560e"
      },
      "router": {}
    }
  }
}
